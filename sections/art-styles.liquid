{% comment %}
  Art Styles Section
{% endcomment %}

<section id="art-styles-teaser" class="section section-cream">
  <div class="container">
    <div class="section-head reveal">
      <div class="eyebrow">{{ section.settings.eyebrow | default: 'Visual Worlds' }}</div>
      <h2 class="section-title">{{ section.settings.title | default: 'Eight styles. One hero.<br>Endless possibilities 🎨' }}</h2>
    </div>
    
    <div class="art-grid">
      {% for i in (1..8) %}
        {% assign style_name = 'style_name_' | append: i %}
        {% assign style_desc = 'style_desc_' | append: i %}
        {% assign style_emoji = 'style_emoji_' | append: i %}
        {% assign style_enabled = 'style_enabled_' | append: i %}
        {% if section.settings[style_enabled] %}
          <div class="art-card reveal" data-style="{{ section.settings[style_name] | handleize }}">
            <div class="art-card-emoji">{{ section.settings[style_emoji] | default: '🎨' }}</div>
            <div class="art-card-overlay">
              <h4>{{ section.settings[style_name] | default: 'Style ' | append: i }}</h4>
              <p>{{ section.settings[style_desc] | default: 'Beautiful illustrations' }}</p>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
    
    <div class="section-cta reveal">
      <a href="{{ section.settings.cta_url | default: '/pages/art-styles' }}" class="btn btn-primary btn-section-cta">
        {{ section.settings.cta_text | default: 'Explore All Styles' }} <span class="arrow">→</span>
      </a>
    </div>
  </div>
</section>

