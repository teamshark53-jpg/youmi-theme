{% comment %}
  Pricing Section
{% endcomment %}

<section class="section">
  <div class="container">
    <div class="pricing-grid">
      {% for i in (1..3) %}
        {% assign plan_enabled = 'plan_enabled_' | append: i %}
        {% assign plan_name = 'plan_name_' | append: i %}
        {% assign plan_tagline = 'plan_tagline_' | append: i %}
        {% assign plan_price = 'plan_price_' | append: i %}
        {% assign plan_featured = 'plan_featured_' | append: i %}
        {% assign plan_popular_text = 'plan_popular_text_' | append: i %}
        
        {% if section.settings[plan_enabled] %}
          <div class="price-card {% if section.settings[plan_featured] %}featured{% endif %} reveal">
            {% if section.settings[plan_featured] %}
              <div class="price-popular">{{ section.settings[plan_popular_text] | default: 'Most Popular' }}</div>
            {% endif %}
            <div class="price-card-header">
              <div class="price-name">{{ section.settings[plan_name] | default: 'Plan ' | append: i }}</div>
              <p class="price-tagline">{{ section.settings[plan_tagline] }}</p>
            </div>
            <div class="price-card-body">
              <div class="price-num">{{ section.settings[plan_price] | default: '£0' }}<small> / book</small></div>
              <ul class="price-features">
                {% for j in (1..5) %}
                  {% assign feature_text = 'plan_' | append: i | append: '_feature_' | append: j %}
                  {% if section.settings[feature_text] != blank %}
                    <li class="price-feature">{{ section.settings[feature_text] }}</li>
                  {% endif %}
                {% endfor %}
              </ul>
            </div>
            <div class="price-card-footer">
              {% assign cta_text = 'plan_' | append: i | append: '_cta_text' %}
              {% assign cta_url = 'plan_' | append: i | append: '_cta_url' %}
              <a href="{{ section.settings[cta_url] | default: '/pages/get-started' }}" class="btn {% if section.settings[plan_featured] %}btn-primary{% else %}btn-ghost{% endif %}">
                {{ section.settings[cta_text] | default: 'Get Started' }}
              </a>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

