{% comment %}
  CTA Section
{% endcomment %}

<section id="cta">
  <div class="cta-section">
    <div class="cta-emoji-bg">{{ section.settings.emoji | default: '✨' }}</div>
    <div class="container" style="padding: 80px 32px; position: relative; z-index: 1;">
      <div class="reveal">
        <h2 class="cta-title">{{ section.settings.title | default: 'Start a story tonight 🪄' }}</h2>
        <p class="cta-subtitle">{{ section.settings.subtitle | default: 'Your first book is on us. No credit card, no clock — just a name, an age, and a little imagination.' }}</p>
        <a href="{{ section.settings.cta_url | default: '/pages/get-started' }}" class="btn btn-primary">
          {{ section.settings.cta_text | default: 'Get My Free Story' }} <span class="arrow">→</span>
        </a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CTA Section",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "emoji",
      "label": "Background Emoji",
      "default": "✨"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Start a story tonight 🪄"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Your first book is on us. No credit card, no clock — just a name, an age, and a little imagination."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "Get My Free Story"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA Button URL"
    }
  ],
  "presets": [
    {
      "name": "CTA Section"
    }
  ]
}
{% endschema %}
