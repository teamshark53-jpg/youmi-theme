{% comment %}
  Features Teaser Section
{% endcomment %}

<section id="features-teaser" class="section">
  <div class="container">
    <div class="section-head reveal">
      <div class="eyebrow">{{ section.settings.eyebrow | default: 'Why Families Love YOUMI' }}</div>
      <h2 class="section-title">{{ section.settings.title | default: 'Built for the way<br>children actually read 💖' }}</h2>
    </div>
    
    <div class="feature-grid">
      {% for i in (1..4) %}
        {% assign feature_enabled = 'feature_enabled_' | append: i %}
        {% assign feature_emoji = 'feature_emoji_' | append: i %}
        {% assign feature_title = 'feature_title_' | append: i %}
        {% assign feature_desc = 'feature_desc_' | append: i %}
        {% if section.settings[feature_enabled] %}
          <div class="feature-card reveal">
            <div class="feature-icon">{{ section.settings[feature_emoji] | default: '✨' }}</div>
            <h3>{{ section.settings[feature_title] | default: 'Feature ' | append: i }}</h3>
            <p>{{ section.settings[feature_desc] | default: 'Feature description goes here.' }}</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>
    
    <div class="section-cta reveal">
      <a href="{{ section.settings.cta_url | default: '/pages/features' }}" class="btn btn-primary btn-section-cta">
        {{ section.settings.cta_text | default: 'See All Features' }} <span class="arrow">→</span>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Features Teaser",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Why Families Love YOUMI"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Section Title",
      "default": "Built for the way<br>children actually read 💖"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "See All Features"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA Button URL"
    },
    {
      "type": "header",
      "content": "Features"
    },
    {
      "type": "checkbox",
      "id": "feature_enabled_1",
      "label": "Show Feature 1",
      "default": true
    },
    {
      "type": "text",
      "id": "feature_emoji_1",
      "label": "Feature 1 Emoji",
      "default": "🧒"
    },
    {
      "type": "text",
      "id": "feature_title_1",
      "label": "Feature 1 Title",
      "default": "A face that holds"
    },
    {
      "type": "textarea",
      "id": "feature_desc_1",
      "label": "Feature 1 Description",
      "default": "From a single photo we match skin tone, hair, glasses, the favourite hoodie. The likeness carries through every page."
    },
    {
      "type": "checkbox",
      "id": "feature_enabled_2",
      "label": "Show Feature 2",
      "default": true
    },
    {
      "type": "text",
      "id": "feature_emoji_2",
      "label": "Feature 2 Emoji",
      "default": "📝"
    },
    {
      "type": "text",
      "id": "feature_title_2",
      "label": "Feature 2 Title",
      "default": "Stories that remember"
    },
    {
      "type": "textarea",
      "id": "feature_desc_2",
      "label": "Feature 2 Description",
      "default": "Pet names, family jokes, the bedtime routine — woven in until the book reads like a memory, not a template."
    },
    {
      "type": "checkbox",
      "id": "feature_enabled_3",
      "label": "Show Feature 3",
      "default": true
    },
    {
      "type": "text",
      "id": "feature_emoji_3",
      "label": "Feature 3 Emoji",
      "default": "🌍"
    },
    {
      "type": "text",
      "id": "feature_title_3",
      "label": "Feature 3 Title",
      "default": "Three languages"
    },
    {
      "type": "textarea",
      "id": "feature_desc_3",
      "label": "Feature 3 Description",
      "default": "English, French, and Arabic — or any combination. The same book in two languages at no extra cost."
    },
    {
      "type": "checkbox",
      "id": "feature_enabled_4",
      "label": "Show Feature 4",
      "default": true
    },
    {
      "type": "text",
      "id": "feature_emoji_4",
      "label": "Feature 4 Emoji",
      "default": "🔁"
    },
    {
      "type": "text",
      "id": "feature_title_4",
      "label": "Feature 4 Title",
      "default": "Free revisions"
    },
    {
      "type": "textarea",
      "id": "feature_desc_4",
      "label": "Feature 4 Description",
      "default": "Don't love the first draft? Rewrite the chapters, redraw the spreads, change the art style. You pay only when it's right."
    }
  ],
  "presets": [
    {
      "name": "Features Teaser"
    }
  ]
}
{% endschema %}
